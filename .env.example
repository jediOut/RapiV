# Docker database settings
POSTGRES_USER=rapiv_app
POSTGRES_PASSWORD=replace-with-a-strong-local-password
POSTGRES_DB=rapi_db
POSTGRES_PORT=5433
REDIS_HOST=localhost
REDIS_PORT=6379

# Backend database settings
BACKEND_PORT=3000
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=rapiv_app
DB_PASSWORD=replace-with-a-strong-local-password
DB_NAME=rapi_db
DB_SYNCHRONIZE=false
DB_LOGGING=false
PAYMENT_QUEUE_CONCURRENCY=8
ORDER_OFFER_QUEUE_CONCURRENCY=6
DELIVERY_OFFER_TTL_MINUTES=15
COURIER_DELIVERY_TIMEOUT_MINUTES=40
JWT_SECRET=replace-with-a-strong-jwt-secret
PUBLIC_API_URL=https://api.example.com
PUBLIC_APP_URL=rapiv://payments
BUSINESS_APP_URL=rapiv-negocio://payments
COURIER_APP_URL=rapiv-repartidor://payments
STRIPE_SECRET_KEY=sk_test_replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_replace-with-stripe-webhook-secret
RAPIV_PLATFORM_FEE_BPS=700
RAPIV_CASH_PLATFORM_FEE_BPS=700
CASH_SETTLEMENT_CUTOFF_HOUR=22
CASH_SETTLEMENT_CUTOFF_MINUTE=0
CASH_SETTLEMENT_GRACE_MINUTES=30
CASH_SETTLEMENT_TIMEZONE_OFFSET_MINUTES=-360
CASH_SETTLEMENT_AUTO_RUN=true
BUSINESS_CASH_PAYOUT_TIMEOUT_MINUTES=120
BUSINESS_COMMISSION_SETTLEMENT_DAY_OF_WEEK=1
BUSINESS_COMMISSION_SETTLEMENT_CUTOFF_HOUR=10
BUSINESS_COMMISSION_SETTLEMENT_CUTOFF_MINUTE=0
BUSINESS_COMMISSION_SETTLEMENT_TIMEZONE_OFFSET_MINUTES=-360
BUSINESS_COMMISSION_SETTLEMENT_AUTO_RUN=true
DELIVERY_FEE_CENTS=3000
COURIER_PAYOUT_CENTS=2500
CARD_PAYMENT_MINIMUM_CENTS=18000
COURIER_WALLET_TOPUP_MINIMUM_CENTS=20000
AWS_REGION=us-east-1
AWS_S3_BUCKET=rapiv-media-dev
AWS_S3_PUBLIC_BASE_URL=https://rapiv-media-dev.s3.us-east-1.amazonaws.com

# pgAdmin settings
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=replace-with-a-strong-local-password

# Observability
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-local-password
