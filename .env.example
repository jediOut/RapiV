# Docker database settings
POSTGRES_USER=rapiv_app
POSTGRES_PASSWORD=replace-with-a-strong-local-password
POSTGRES_DB=rapi_db
POSTGRES_PORT=5433
REDIS_HOST=localhost
REDIS_PORT=6379

# Backend database settings
BACKEND_PORT=3000
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=rapiv_app
DB_PASSWORD=replace-with-a-strong-local-password
DB_NAME=rapi_db
DB_SYNCHRONIZE=false
DB_LOGGING=false
PAYMENT_QUEUE_CONCURRENCY=8
ORDER_OFFER_QUEUE_CONCURRENCY=6
DELIVERY_OFFER_TTL_MINUTES=15
JWT_SECRET=replace-with-a-strong-jwt-secret
PUBLIC_API_URL=https://api.example.com
MERCADOPAGO_ACCESS_TOKEN=TEST-replace-with-mercadopago-access-token
MERCADOPAGO_WEBHOOK_SECRET=replace-with-a-strong-mercadopago-webhook-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=rapiv-media-dev
AWS_S3_PUBLIC_BASE_URL=https://rapiv-media-dev.s3.us-east-1.amazonaws.com

# pgAdmin settings
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=replace-with-a-strong-local-password

# Observability
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-local-password
