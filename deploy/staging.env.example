# Domain exposed to the Expo apps. Example: staging-api.rapiv.com
STAGING_DOMAIN=staging-api.example.com
ACME_EMAIL=admin@example.com

# Application
NODE_ENV=production
LOG_LEVEL=info
JWT_SECRET=replace-with-a-long-random-secret
PUBLIC_API_URL=https://staging-api.example.com/api
PUBLIC_APP_URL=rapiv://payments
BUSINESS_APP_URL=rapiv-negocio://payments
COURIER_APP_URL=https://staging-api.example.com/api

# Database
POSTGRES_USER=rapiv_app
POSTGRES_PASSWORD=replace-with-a-strong-staging-password
POSTGRES_DB=rapi_staging
DB_USERNAME=rapiv_app
DB_PASSWORD=replace-with-a-strong-staging-password
DB_NAME=rapi_staging
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Redis / queues
REDIS_HOST=redis
REDIS_PORT=6379
PAYMENT_QUEUE_CONCURRENCY=2
ORDER_OFFER_QUEUE_CONCURRENCY=2
ORDER_LIFECYCLE_QUEUE_CONCURRENCY=2
BUSINESS_ACCEPTANCE_TIMEOUT_MINUTES=10
BUSINESS_READY_TIMEOUT_MINUTES=30
DELIVERY_OFFER_TTL_MINUTES=15

# Payments - use Stripe test keys in staging.
STRIPE_SECRET_KEY=sk_test_replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_replace-with-stripe-webhook-secret
GOOGLE_CLIENT_IDS=google-web-client-id.apps.googleusercontent.com,google-ios-client-id.apps.googleusercontent.com,google-android-client-id.apps.googleusercontent.com
RAPIV_PLATFORM_FEE_BPS=1000
RAPIV_CASH_PLATFORM_FEE_BPS=500
CASH_SETTLEMENT_CUTOFF_HOUR=22
CASH_SETTLEMENT_CUTOFF_MINUTE=0
CASH_SETTLEMENT_GRACE_MINUTES=30
CASH_SETTLEMENT_TIMEZONE_OFFSET_MINUTES=-360
CASH_SETTLEMENT_AUTO_RUN=true
BUSINESS_CASH_PAYOUT_TIMEOUT_MINUTES=120
BUSINESS_COMMISSION_SETTLEMENT_DAY_OF_WEEK=1
BUSINESS_COMMISSION_SETTLEMENT_CUTOFF_HOUR=10
BUSINESS_COMMISSION_SETTLEMENT_CUTOFF_MINUTE=0
BUSINESS_COMMISSION_SETTLEMENT_TIMEZONE_OFFSET_MINUTES=-360
BUSINESS_COMMISSION_SETTLEMENT_AUTO_RUN=true
DELIVERY_FEE_CENTS=3000
COURIER_PAYOUT_CENTS=2000

# Media uploads
AWS_REGION=us-east-1
AWS_S3_BUCKET=rapiv-media-staging
AWS_S3_PUBLIC_BASE_URL=https://rapiv-media-staging.s3.us-east-1.amazonaws.com
