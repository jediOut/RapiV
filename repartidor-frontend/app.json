{
  "expo": {
    "name": "RapiV Repartidor",
    "slug": "rapiv-repartidor",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": [
      "rapiv-repartidor",
      "com.rapiv.courier"
    ],
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rapiv.courier",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RapiV usa tu ubicacion durante la entrega para mostrar la ruta al cliente."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.rapiv.courier",
      "versionCode": 1
    },
    "plugins": [
      "expo-location",
      "expo-notifications",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "f1e42dad-b41c-4e9e-a20e-7e985c07ee79"
      }
    }
  }
}
