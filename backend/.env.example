# Application
NODE_ENV=development
PORT=3000
JWT_SECRET=replace-with-a-long-random-secret
PUBLIC_API_URL=https://api.example.com
MERCADOPAGO_ACCESS_TOKEN=TEST-replace-with-mercadopago-access-token
MERCADOPAGO_WEBHOOK_SECRET=replace-with-a-strong-mercadopago-webhook-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=rapiv-media-dev
AWS_S3_PUBLIC_BASE_URL=https://rapiv-media-dev.s3.us-east-1.amazonaws.com

# Database - PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=rapiv_app
DB_PASSWORD=replace-with-the-same-password-used-by-docker
DB_NAME=rapi_db

# TypeORM Configuration
DB_SYNCHRONIZE=false
DB_LOGGING=false
REDIS_HOST=localhost
REDIS_PORT=6379
PAYMENT_QUEUE_CONCURRENCY=8
DELIVERY_OFFER_TTL_MINUTES=15

# Optional: Email configuration (for future use)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

