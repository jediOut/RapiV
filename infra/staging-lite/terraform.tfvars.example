aws_region          = "us-east-1"
project_name        = "rapiv"
instance_type       = "t3.micro"
key_name            = "rapiv-staging-key"
allowed_ssh_cidr    = "replace-with-your-public-ip/32"
root_volume_size_gb = 20

hosted_zone_id = ""
staging_domain = "staging-api.local"

# Leave empty to generate: rapiv-media-staging-<aws-account-id>
media_bucket_name = ""
