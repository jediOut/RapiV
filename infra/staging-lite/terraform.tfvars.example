aws_region          = "us-east-1"
project_name        = "rapiv"
instance_type       = "t3.micro"
key_name            = "replace-with-existing-ec2-key-pair"
allowed_ssh_cidr    = "replace-with-your-public-ip/32"
root_volume_size_gb = 20

# If you already manage the domain in Route 53, set the hosted zone ID.
# Leave empty and create the DNS A record manually if the domain is outside AWS.
hosted_zone_id = ""
staging_domain = "staging-api.example.com"
